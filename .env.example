# PostgreSQL kapcsolat – a docker-compose.yml ezt az adatbázist indítja el.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/webmotor

# Titkos kulcs a bejelentkezési tokenekhez. Élesben generálj újat:  openssl rand -hex 32
PAYLOAD_SECRET=valts-le-egy-hosszu-veletlen-kulcsra

# Az oldal publikus címe – ebből készül a sitemap, a canonical és az OG képek URL-je.
# Élesben: https://sajatdomain.hu
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ── S3-kompatibilis médiatárolás (élesben KÖTELEZŐ, fejlesztéshez nem kell) ──
# Ha a három fő adat (bucket + kulcspár) ki van töltve, a feltöltött képek
# S3-ba kerülnek; üresen hagyva a helyi fájlrendszerre (fejlesztői mód).
# Működik: AWS S3, Cloudflare R2, MinIO, Supabase Storage, DigitalOcean Spaces…
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# AWS-nél a régió (pl. eu-central-1); R2/MinIO-nál maradhat üresen ("auto").
S3_REGION=
# Csak S3-KOMPATIBILIS tárolónál kell (pl. R2: https://<accountid>.r2.cloudflarestorage.com);
# valódi AWS S3-nál hagyd üresen.
S3_ENDPOINT=
